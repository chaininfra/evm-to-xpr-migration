{
  "name": "hello-world-contract",
  "version": "1.0.0",
  "description": "Simple Hello World contract for Proton blockchain",
  "main": "contract.ts",
  "scripts": {
    "build": "npx proton-asc contract.ts 2>/dev/null || npx proton-asc contract.ts",
